import pandas as pd
from surprise import Dataset, Reader, SVD
from surprise.model_selection import train_test_split
from surprise.accuracy import rmse, mae
from google.colab import files
uploaded = files.upload()
ratings = pd.read_csv("ratings.csv")
movies = pd.read_csv("movies.csv")

ratings.head()
reader = Reader(rating_scale=(0.5, 5))

data = Dataset.load_from_df(
    ratings[['userId', 'movieId', 'rating']],
    reader
)
trainset, testset = train_test_split(data, test_size=0.2)
model = SVD()

model.fit(trainset)
predictions = model.test(testset)
rmse(predictions)
mae(predictions)
user_id = 1

movie_ids = ratings['movieId'].unique()

watched = ratings[ratings['userId'] == user_id]['movieId']

not_watched = [movie for movie in movie_ids if movie not in watched.values]

predictions = []

for movie_id in not_watched[:20]:
    pred = model.predict(user_id, movie_id)
    predictions.append((movie_id, pred.est))

predictions.sort(key=lambda x: x[1], reverse=True)

top_recommendations = predictions[:5]

for movie_id, rating in top_recommendations:
    movie_name = movies[movies['movieId'] == movie_id]['title'].values[0]
    print(movie_name, "Predicted Rating:", rating)
